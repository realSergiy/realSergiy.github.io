{"name":"polyglot","icon":"vr","settings":"{\"settings\":\"{\\n  // ─── Editor: core ───────────────────────────────────────────────\\n  \\\"editor.accessibilitySupport\\\": \\\"off\\\",\\n  \\\"editor.fontFamily\\\": \\\"JetBrainsMono NF\\\",\\n  \\\"editor.fontLigatures\\\": true,\\n  \\\"editor.formatOnSave\\\": true,\\n  \\\"editor.bracketPairColorization.enabled\\\": true,\\n  \\\"editor.guides.bracketPairs\\\": \\\"active\\\",\\n  // ─── Editor: language-specific formatters ───────────────────────\\n  \\\"[markdown]\\\": {\\n    \\\"editor.unicodeHighlight.ambiguousCharacters\\\": true,\\n    \\\"editor.unicodeHighlight.invisibleCharacters\\\": false,\\n    \\\"editor.wordWrap\\\": \\\"on\\\",\\n    \\\"editor.quickSuggestions\\\": {\\n      \\\"comments\\\": \\\"off\\\",\\n      \\\"strings\\\": \\\"off\\\",\\n      \\\"other\\\": \\\"off\\\",\\n    },\\n    \\\"editor.defaultFormatter\\\": \\\"rvben.rumdl\\\",\\n  },\\n  \\\"[toml]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"tamasfe.even-better-toml\\\",\\n  },\\n  \\\"[typescript]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\",\\n  },\\n  \\\"[typescriptreact]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\",\\n  },\\n  \\\"[javascript]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\",\\n  },\\n  \\\"[javascriptreact]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\",\\n  },\\n  \\\"[json]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\",\\n  },\\n  \\\"[jsonc]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"vscode.json-language-features\\\",\\n  },\\n  \\\"[python]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"charliermarsh.ruff\\\",\\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"editor.inlayHints.enabled\\\": \\\"onUnlessPressed\\\",\\n    \\\"editor.codeActionsOnSave\\\": {\\n      \\\"source.fixAll\\\": \\\"explicit\\\",\\n      \\\"source.organizeImports\\\": \\\"explicit\\\",\\n    },\\n  },\\n  \\\"prettier.endOfLine\\\": \\\"crlf\\\",\\n  // ─── Files & explorer ───────────────────────────────────────────\\n  \\\"files.autoSave\\\": \\\"afterDelay\\\",\\n  \\\"files.autoSaveDelay\\\": 5000,\\n  \\\"files.associations\\\": {\\n    \\\"*.md\\\": \\\"markdown\\\",\\n  },\\n  \\\"explorer.confirmDelete\\\": false,\\n  \\\"explorer.confirmDragAndDrop\\\": false,\\n  // ─── JavaScript / TypeScript ────────────────────────────────────\\n  \\\"js/ts.updateImportsOnFileMove.enabled\\\": \\\"always\\\",\\n  \\\"js/ts.implicitProjectConfig.experimentalDecorators\\\": true,\\n  \\\"js/ts.implementationsCodeLens.enabled\\\": true,\\n  \\\"js/ts.implementationsCodeLens.showOnInterfaceMethods\\\": true,\\n  \\\"js/ts.referencesCodeLens.enabled\\\": true,\\n  \\\"js/ts.referencesCodeLens.showOnAllFunctions\\\": true,\\n  // ─── Git & GitLens ──────────────────────────────────────────────\\n  \\\"git.autofetch\\\": true,\\n  \\\"git.confirmSync\\\": false,\\n  \\\"git.enableSmartCommit\\\": true,\\n  \\\"diffEditor.codeLens\\\": true,\\n  \\\"gitlens.codeLens.includeSingleLineSymbols\\\": true,\\n  \\\"gitlens.ai.model\\\": \\\"vscode\\\",\\n  // ─── Workbench / icons / editor associations ────────────────────\\n  \\\"workbench.iconTheme\\\": \\\"vscode-icons\\\",\\n  \\\"vsicons.dontShowNewVersionMessage\\\": true,\\n  \\\"workbench.editorAssociations\\\": {\\n    \\\"*.copilotmd\\\": \\\"vscode.markdown.preview.editor\\\",\\n    \\\"{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc\\\": \\\"default\\\",\\n    \\\"*.qrc\\\": \\\"qt-core.qrcEditor\\\",\\n  },\\n  // ─── Indent Rainbow ─────────────────────────────────────────────\\n  \\\"indentRainbow.indicatorStyle\\\": \\\"light\\\",\\n  \\\"indentRainbow.lightIndicatorStyleLineWidth\\\": 1,\\n  \\\"indentRainbow.colorOnWhiteSpaceOnly\\\": true,\\n  \\\"indentRainbow.colors\\\": [\\n    \\\"rgba(255,255,64,0.3)\\\",\\n    \\\"rgba(127,255,127,0.3)\\\",\\n    \\\"rgba(255,127,255,0.3)\\\",\\n    \\\"rgba(79,236,236,0.3)\\\",\\n  ],\\n  // ─── Terminal ───────────────────────────────────────────────────\\n  \\\"terminal.integrated.fontFamily\\\": \\\"monospace\\\",\\n  // ─── AI assistants (Claude Code, Copilot, chat) ─────────────────\\n  \\\"claudeCode.preferredLocation\\\": \\\"panel\\\",\\n  \\\"github.copilot.nextEditSuggestions.enabled\\\": true,\\n  \\\"chat.tools.terminal.outputLocation\\\": \\\"chat\\\",\\n  // ─── Language: Python ───────────────────────────────────────────\\n  \\\"python.terminal.activateEnvironment\\\": false,\\n  \\\"python.languageServer\\\": \\\"Pylance\\\",\\n  // Type analysis\\n  \\\"python.analysis.typeCheckingMode\\\": \\\"standard\\\",\\n  \\\"python.analysis.diagnosticMode\\\": \\\"workspace\\\",\\n  \\\"python.analysis.useLibraryCodeForTypes\\\": true,\\n  // Inlay hints — inferred types rendered inline (closest analog to TS reference CodeLens)\\n  \\\"python.analysis.inlayHints.variableTypes\\\": true,\\n  \\\"python.analysis.inlayHints.functionReturnTypes\\\": true,\\n  \\\"python.analysis.inlayHints.callArgumentNames\\\": \\\"all\\\",\\n  \\\"python.analysis.inlayHints.pytestParameters\\\": true,\\n  // Auto-imports and cross-file indexing\\n  \\\"python.analysis.autoImportCompletions\\\": true,\\n  \\\"python.analysis.indexing\\\": true,\\n  \\\"python.analysis.packageIndexDepths\\\": [\\n    { \\\"name\\\": \\\"\\\", \\\"depth\\\": 2 },\\n  ],\\n  \\\"python.analysis.includeVenvInWorkspaceSymbols\\\": true,\\n  // Editor ergonomics\\n  \\\"python.analysis.autoFormatStrings\\\": true,\\n  \\\"python.analysis.completeFunctionParens\\\": true,\\n  \\\"python.analysis.gotoDefinitionInStringLiteral\\\": true,\\n  \\\"python.analysis.fixAll\\\": [\\\"source.unusedImports\\\"],\\n  // Testing — gives Run/Debug CodeLens above test functions\\n  \\\"python.testing.pytestEnabled\\\": true,\\n  \\\"python.testing.unittestEnabled\\\": false,\\n  // ─── Language: YA